<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Assign Volunteer</MudText>
    </TitleContent>
    <DialogContent>
        <MudSelect T="Guid" @bind-Value="_selectedVolunteerId" Label="Select Volunteer" Required="true">
            @foreach (var v in Volunteers)
            {
                <MudSelectItem T="Guid" Value="v.Id">@v.FirstName @v.LastName (@v.Email)</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(_selectedVolunteerId == Guid.Empty)">
            Assign
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public IReadOnlyList<Volunteer> Volunteers { get; set; } = [];
    [Parameter] public Guid PickupDeliveryId { get; set; }

    private Guid _selectedVolunteerId;

    private void Submit() => MudDialog.Close(DialogResult.Ok(_selectedVolunteerId));
    private void Cancel() => MudDialog.Cancel();
}
