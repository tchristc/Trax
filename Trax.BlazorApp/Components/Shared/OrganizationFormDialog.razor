<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Organization.Id == Guid.Empty ? "Create Organization" : "Edit Organization")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Organization.Name" Label="Organization Name"
                                  Required="true" RequiredError="Name is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Organization.ContactName" Label="Contact Name" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Organization.Email" Label="Email" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Organization.Phone" Label="Phone" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudCheckBox @bind-Value="Organization.IsActive" Label="Active" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Organization.Address" Label="Address" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Organization.Notes" Label="Notes" Lines="3" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="!_isValid">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Organization Organization { get; set; } = new();

    private MudForm _form = default!;
    private bool _isValid;

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;
        MudDialog.Close(DialogResult.Ok(Organization));
    }

    private void Cancel() => MudDialog.Cancel();
}
