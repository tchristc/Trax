@inject IUserService UserService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Volunteer.Id == Guid.Empty ? "Create Volunteer" : "Edit Volunteer")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Volunteer.FirstName" Label="First Name"
                                  Required="true" RequiredError="First name is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Volunteer.LastName" Label="Last Name"
                                  Required="true" RequiredError="Last name is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Volunteer.Email" Label="Email"
                                  InputType="InputType.Email"
                                  Required="true" RequiredError="Email is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Volunteer.Phone" Label="Phone" />
                </MudItem>
                @if (Volunteer.Id == Guid.Empty)
                {
                    <MudItem xs="12">
                        <MudSelect T="Guid" @bind-Value="Volunteer.AppUserId" Label="Linked User Account"
                                   Required="true" RequiredError="A user account is required">
                            @foreach (var user in _users)
                            {
                                <MudSelectItem T="Guid" Value="user.Id">@user.DisplayName (@user.Email)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="Volunteer.IsActive" Label="Active" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Volunteer.Notes" Label="Notes" Lines="3" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="!_isValid">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Volunteer Volunteer { get; set; } = new();

    private MudForm _form = default!;
    private bool _isValid;
    private IReadOnlyList<AppUser> _users = [];

    protected override async Task OnInitializedAsync()
    {
        _users = await UserService.GetAllUsersAsync();
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;
        MudDialog.Close(DialogResult.Ok(Volunteer));
    }

    private void Cancel() => MudDialog.Cancel();
}
